# === API de Adzuna (GRATIS) — cubre España, México y EE. UU. ===
# 1. Regístrate en https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# === API de Jooble (GRATIS) — cubre el resto de Latinoamérica ===
# Solicita tu clave en https://jooble.org/api/about
JOOBLE_API_KEY=

# === API de Pexels (GRATIS) — fotos con licencia libre para cabeceras ===
# Clave gratis en https://www.pexels.com/api/
PEXELS_API_KEY=

# Copia este archivo a ".env" y pega tus claves. Sin claves el sitio compila igual.
