---
import { SITE } from '../config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  titulo: string;
  descripcion?: string;
  jsonLd?: object | object[]; // datos estructurados extra para esta página
}
const { titulo, descripcion = SITE.descripcion, jsonLd } = Astro.props;
const tituloCompleto = titulo === SITE.nombre ? titulo : `${titulo} | ${SITE.nombre}`;
const canonical = new URL(Astro.url.pathname, SITE.url).href;

// Datos estructurados de todo el sitio (Organización + Web con buscador).
const sitioJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE.nombre,
    url: SITE.url,
    description: SITE.descripcion,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.nombre,
    url: SITE.url,
  },
];

const extra = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const todosJsonLd = [...sitioJsonLd, ...extra];
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{tituloCompleto}</title>
    <meta name="description" content={descripcion} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={tituloCompleto} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={SITE.nombre} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#161a4d" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {todosJsonLd.map((d) => (
      <script type="application/ld+json" set:html={JSON.stringify(d)} />
    ))}

    {SITE.adsenseClientId && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${SITE.adsenseClientId}`}
        crossorigin="anonymous"
      ></script>
    )}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
