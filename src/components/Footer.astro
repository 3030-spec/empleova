---
import { SITE } from '../config';
const anio = new Date().getFullYear();
---
<footer class="footer">
  <div class="contenedor">
    <div class="cols">
      <div>
        <h4>{SITE.nombre}</h4>
        <p>Tu portal de ofertas de empleo y guías para conseguir trabajo en España y Latinoamérica.</p>
      </div>
      <div>
        <h4>Secciones</h4>
        <ul>
          <li><a href="/empleos">Ofertas de empleo</a></li>
          <li><a href="/guias">Guías de empleo</a></li>
          <li><a href="/sobre-nosotros">Sobre nosotros</a></li>
          <li><a href="/contacto">Contacto</a></li>
        </ul>
      </div>
      <div>
        <h4>Legal</h4>
        <ul>
          <li><a href="/privacidad">Política de privacidad</a></li>
          <li><a href="/aviso-legal">Aviso legal</a></li>
          <li><a href="/cookies">Política de cookies</a></li>
        </ul>
      </div>
    </div>
    <div class="legal">
      <p>© {anio} {SITE.nombre}. Este sitio no ofrece empleos directamente; es un puente informativo entre aspirantes y oferentes.</p>
    </div>
  </div>
</footer>
